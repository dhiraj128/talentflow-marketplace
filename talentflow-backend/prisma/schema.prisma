generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  passwordHash      String?
  role              Role               @default(CANDIDATE)
  isEmailVerified   Boolean            @default(false)
  phoneVerified     Boolean            @default(false)
  phoneNumber       String?            @unique
  countryCode       String?
  verificationMethod VerificationMethod? @default(EMAIL)
  refreshToken      String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  avatarUrl         String?
  githubId          String?            @unique
  googleId          String?            @unique
  provider          String?
  status            UserStatus         @default(ACTIVE)
  auditLogs         AuditLog[]         @relation("ActionBy")
  candidateProfile  CandidateProfile?
  employerProfile   EmployerProfile?
  freelancerProfile FreelancerProfile?
  sentMessages      Message[]
  notifications     Notification[]
  subscriptions Subscription[]
  trainerProfile    TrainerProfile?
}

model EmployerProfile {
  id             String           @id @default(uuid())
  userId         String           @unique
  companyName    String
  industry       String?
  logoUrl        String?
  subscription   SubscriptionTier @default(FREE)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  bio            String?
  location       String?
  phone          String?
  websiteUrl     String?
  billing        Billing[]
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs           Job[]
  projectRequests ProjectRequest[]
  reviews Review[]
  interviews     Interview[]
}

model CandidateProfile {
  id           String           @id @default(uuid())
  userId       String           @unique
  fullName     String
  title        String?
  location     String?
  avatarUrl    String?
  resumeUrl    String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  bio          String?
  education    Json?
  experience   Json?
  githubUrl    String?
  linkedinUrl  String?
  phone        String?
  portfolioUrl String?
  applications Application[]
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills       CandidateSkill[]
  certificates Certificate[]
  coverLetters CoverLetter[]
  enrollments  Enrollment[]
  resumes      Resume[]
  interviews   Interview[]
}

model TrainerProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  fullName  String
  bio       String?
  expertise String?
  avatarUrl String?
  rating    Float?   @default(0.0)
  isVerified Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  courses   Course[]
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FreelancerProfile {
  id              String            @id @default(uuid())
  userId          String            @unique
  fullName        String
  title           String?
  bio             String?
  hourlyRate      Float?
  portfolioUrl    String?
  githubUrl       String?
  avatarUrl       String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  availability    String?
  isVerified      Boolean           @default(false)
  location        String?
  rating          Float             @default(0.0)
  reviewCount     Int               @default(0)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills FreelancerSkill[]
  projectRequests ProjectRequest[]
  reviews Review[]
}

model Job {
  id             String          @id @default(uuid())
  employerId     String
  title          String
  location       String?
  type           String?
  salaryRange    String?
  description    String
  status         JobStatus       @default(DRAFT)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
  applications   Application[]
  employer       EmployerProfile @relation(fields: [employerId], references: [id], onDelete: Cascade)
  requiredSkills JobSkill[]
}

model Application {
  id          String            @id @default(uuid())
  candidateId String
  jobId       String
  resumeId    String?
  status      ApplicationStatus @default(PENDING)
  matchScore  Int               @default(0)
  appliedAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  candidate   CandidateProfile  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resume      Resume?           @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  interviews  Interview[]

  @@unique([candidateId, jobId])
}

model Skill {
  id              String            @id @default(uuid())
  name            String            @unique
  category        String?
  createdAt       DateTime          @default(now())
  candidates      CandidateSkill[]
  skills FreelancerSkill[]
  jobs            JobSkill[]
}

model CandidateSkill {
  candidateId String
  skillId     String
  proficiency Int?
  candidate   CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([candidateId, skillId])
}

model JobSkill {
  jobId       String
  skillId     String
  isMandatory Boolean @default(true)
  job         Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([jobId, skillId])
}

model Course {
  id           String         @id @default(uuid())
  title        String
  category     String
  description  String
  thumbnailUrl String?
  rating       Float?         @default(0.0)
  studentCount Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  trainerId    String
  duration     String?
  level        String?
  price        Float          @default(0.0)
  status       CourseStatus   @default(DRAFT)
  assessment Assessment?
  certificates Certificate[]
  trainer      TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  modules CourseModule[]
  enrollments  Enrollment[]
}

model Enrollment {
  id                String              @id @default(uuid())
  candidateId       String
  courseId          String
  progress          Int                 @default(0)
  enrolledAt        DateTime            @default(now())
  completedAt       DateTime?
  assessmentAttempts AssessmentAttempt[]
  candidate         CandidateProfile    @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonProgress LessonProgress[]

  @@unique([candidateId, courseId])
}

model Certificate {
  id             String           @id @default(uuid())
  candidateId    String
  courseId       String
  issuedAt       DateTime         @default(now())
  certificateUrl String?
  candidate      CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([candidateId, courseId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Conversation {
  id             String    @id @default(uuid())
  participant1Id String
  participant2Id String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  messages       Message[]

  @@unique([participant1Id, participant2Id])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  actionBy  String
  action    String
  resource  String
  details   Json?
  createdAt DateTime @default(now())
  user User @relation("ActionBy", fields: [actionBy], references: [id], onDelete: Cascade)
}

model Billing {
  id         String          @id @default(uuid())
  employerId String
  invoiceId  String          @unique
  amount     Float
  status     String
  issuedAt   DateTime        @default(now())
  employer   EmployerProfile @relation(fields: [employerId], references: [id], onDelete: Cascade)
}

model Resume {
  id          String           @id @default(uuid())
  title       String?
  type        String           @default("ORIGINAL") // ORIGINAL or ATS
  fileName    String?
  storageKey  String?
  bucket      String?
  mimeType    String?
  size        Int?
  version     Int              @default(1)
  createdAt   DateTime         @default(now())
  candidateId String
  content     Json?
  fileUrl     String?
  isDefault   Boolean          @default(false)
  updatedAt   DateTime         @updatedAt
  candidate   CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  applications Application[]
}

model ResumeTemplate {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
}

model ResumeOrder {
  id        String   @id @default(uuid())
  status    String
  createdAt DateTime @default(now())
}

model ATSResult {
  id        String   @id @default(uuid())
  score     Int
  createdAt DateTime @default(now())
}

model ResumeReview {
  id        String   @id @default(uuid())
  feedback  String
  createdAt DateTime @default(now())
}

model ResumePayment {
  id        String   @id @default(uuid())
  amount    Float
  createdAt DateTime @default(now())
}

model ResumeWriter {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
}

model CoverLetter {
  id          String           @id @default(uuid())
  content     String
  createdAt   DateTime         @default(now())
  candidateId String
  title       String?
  updatedAt   DateTime         @updatedAt
  candidate   CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model ResumeVerification {
  id        String   @id @default(uuid())
  status    String
  createdAt DateTime @default(now())
}

model EmployerResumeView {
  id       String   @id @default(uuid())
  viewedAt DateTime @default(now())
}

model IdentityVerificationDocument {
  id          String   @id @default(uuid())
  documentUrl String
  createdAt   DateTime @default(now())
}

model Assessment {
  id                String              @id
  courseId          String              @unique
  title             String
  passingScore      Int                 @default(70)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  assessmentAttempts AssessmentAttempt[]
  questions Question[]
}

model AssessmentAttempt {
  id           String     @id @default(uuid())
  enrollmentId String
  assessmentId String
  score        Int
  passed       Boolean
  attemptedAt  DateTime   @default(now())
  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
}

model Category {
  id          String   @id
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Coupon {
  id            String    @id
  code          String    @unique
  discountType  String
  discountValue Float
  maxUses       Int?
  usedCount     Int       @default(0)
  expiryDate    DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt DateTime @updatedAt
}

model CourseModule {
  id          String   @id
  courseId    String
  title       String
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt DateTime @updatedAt
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]
}

model Designation {
  id          String   @id
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FreelancerSkill {
  freelancerId      String
  skillId           String
  proficiency       Int?
  freelancer FreelancerProfile @relation(fields: [freelancerId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([freelancerId, skillId])
}

model Lesson {
  id             String           @id
  moduleId       String
  title          String
  content        String?
  videoUrl       String?
  duration       Int?
  order          Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt DateTime @updatedAt
  module CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  lessonProgress LessonProgress[]
}

model LessonProgress {
  enrollmentId String
  lessonId     String
  isCompleted  Boolean    @default(false)
  completedAt  DateTime?
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@id([enrollmentId, lessonId])
}

model Location {
  id        String   @id
  name      String   @unique
  country   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Offer {
  id          String    @id
  title       String
  description String?
  discount    Float
  bannerUrl   String?
  isActive    Boolean   @default(true)
  validUntil  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt DateTime @updatedAt
}

model Plan {
  id           String         @id
  name         String         @unique
  description  String?
  price        Float
  billingCycle String         @default("MONTHLY")
  features     Json
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt DateTime @updatedAt
  subscriptions Subscription[]
}

model ProjectRequest {
  id                String               @id @default(uuid())
  employerId        String
  freelancerId      String
  title             String
  description       String
  budget            Float
  status            ProjectRequestStatus @default(PENDING)
  createdAt         DateTime             @default(now())
  updatedAt DateTime @updatedAt
  employer EmployerProfile @relation(fields: [employerId], references: [id], onDelete: Cascade)
  freelancer FreelancerProfile @relation(fields: [freelancerId], references: [id], onDelete: Cascade)
  reviews Review[]
}

model Question {
  id           String     @id
  assessmentId String
  text         String
  options      Json
  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

model Review {
  id                String            @id @default(uuid())
  employerId        String
  freelancerId      String
  projectRequestId  String
  rating            Int
  text              String?
  createdAt         DateTime          @default(now())
  employer EmployerProfile @relation(fields: [employerId], references: [id], onDelete: Cascade)
  freelancer FreelancerProfile @relation(fields: [freelancerId], references: [id], onDelete: Cascade)
  ProjectRequest    ProjectRequest    @relation(fields: [projectRequestId], references: [id], onDelete: Cascade)

  @@unique([employerId, projectRequestId])
}

model Subscription {
  id        String   @id
  userId    String
  planId    String
  status    String   @default("ACTIVE")
  startDate DateTime @default(now())
  endDate   DateTime
  autoRenew Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  plan Plan @relation(fields: [planId], references: [id])
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  EMPLOYER
  CANDIDATE
  FREELANCER
  TRAINER
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  SHORTLISTED
  INTERVIEWING
  OFFERED
  HIRED
  REJECTED
}

enum SubscriptionTier {
  FREE
  PRO
  ENTERPRISE
}

enum CourseStatus {
  DRAFT
  PENDING
  PUBLISHED
  REJECTED
}

enum ProjectRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Interview {
  id              String          @id @default(uuid())
  applicationId   String
  employerId      String
  candidateId     String
  scheduledAt     DateTime
  duration        Int             @default(60) // Duration in minutes
  timezone        String          @default("UTC")
  meetingProvider String?         // e.g., 'Zoom', 'Google Meet', 'Teams'
  meetingUrl      String?
  notes           String?
  feedback        String?
  status          InterviewStatus @default(SCHEDULED)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  application     Application     @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  employer        EmployerProfile @relation(fields: [employerId], references: [id], onDelete: Cascade)
  candidate       CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

enum VerificationMethod {
  EMAIL
  PHONE
  GOOGLE
  GITHUB
}

enum OtpPurpose {
  REGISTER
  LOGIN
  FORGOT_PASSWORD
  CHANGE_EMAIL
  CHANGE_PHONE
}

model OTP {
  id          String     @id @default(uuid())
  identifier  String
  codeHash    String
  purpose     OtpPurpose
  expiresAt   DateTime
  attempts    Int        @default(0)
  createdAt   DateTime   @default(now())
  verifiedAt  DateTime?

  @@index([identifier])
  @@index([expiresAt])
}

